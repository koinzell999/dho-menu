rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public menu prices: readable by everyone, writable by signed-in admins.
    match /prices/menu {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Public menu settings (hidden items): readable by everyone, writable by signed-in admins.
    match /settings/menu {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Weekly click counters: readable by everyone, writable by everyone (increment only).
    match /clicks/{weekId} {
      allow read: if true;
      allow write: if true;
    }

    // Orders: one document per table (table1 … table6).
    // - Anyone can read (customers track their own order on the status page).
    // - Authenticated cashier: full read/write (status changes, deletions).
    // - Unauthenticated customer: may only create or update with status = 'new'.
    match /orders/{tableId} {
      allow read: if true;
      allow write: if request.auth != null;
      allow create: if request.auth == null
                    && request.resource.data.status == 'new';
      allow update: if request.auth == null
                    && request.resource.data.status == 'new';
    }

    // Order history: written by cashier when an order is marked Paid.
    // Only authenticated cashier can read/write.
    match /orderHistory/{orderId} {
      allow read, write: if request.auth != null;
    }

    // Daily analytics: aggregated KPIs written at payment time.
    // Only authenticated cashier can read/write.
    match /analytics/{dateId} {
      allow read, write: if request.auth != null;

      // Minute-level sub-documents (HH:MM keys)
      match /minutes/{minuteId} {
        allow read, write: if request.auth != null;
      }
    }

    // AI summaries: written by Cloud Functions, read by cashier.
    match /aiSummaries/{dateId} {
      allow read: if request.auth != null;
      allow write: if false; // written only by Cloud Functions (admin SDK)
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
