rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public menu prices: readable by everyone, writable by signed-in admins.
    match /prices/menu {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Public menu settings (hidden items): readable by everyone, writable by signed-in admins.
    match /settings/menu {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
